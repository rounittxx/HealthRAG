# Copy this to .env and fill in your values
# Never commit the actual .env file to git!

OPENAI_API_KEY=your_openai_api_key_here

# optional: set to true if you want to use local Ollama instead of OpenAI
USE_LOCAL_LLM=false

# API settings (leave defaults unless you have a conflict)
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
API_BASE_URL=http://localhost:8000
